{
  "manifest_version": 3,
  "name": "Anti-Deepfake-Box",
  "version": "1.0.0",
  "description": "Real-time deepfake detection overlay for browser video",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8000/*", "<all_urls>"],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Anti-Deepfake-Box"
  }
}
